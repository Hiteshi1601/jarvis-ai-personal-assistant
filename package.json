{
  "name": "jarvis-workspace",
  "version": "1.0.0",
  "description": "Root workspace management scripts for JARVIS AI platform",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "db:start": "docker-compose -f backend/docker-compose.yml up -d",
    "db:stop": "docker-compose -f backend/docker-compose.yml down",
    "prisma:generate": "npm run prisma:generate --prefix backend",
    "prisma:migrate": "npm run prisma:migrate --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend"
  },
  "dependencies": {
    "groq-sdk": "^1.3.0"
  }
}
