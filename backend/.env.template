# Express Server Port
PORT=5000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# PostgreSQL Database Connection URL
DATABASE_URL="postgresql://postgres:jarvispassword@localhost:5432/jarvis_db?schema=public"

# Google OAuth Credentials (Get these from Google Cloud Console)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/auth/google/callback"

# Groq API Key & Model (Get from Groq Console)
GROQ_API_KEY="YOUR_GROQ_API_KEY"
GROQ_MODEL="llama-3.3-70b-versatile"

# JWT Secret for cookie sessions
JWT_SECRET="YOUR_SUPER_SECRET_JWT_SIGNING_KEY"

# AES-256 encryption key for sensitive DB fields (OAuth tokens)
# Must be exactly 32 bytes (64 hex characters)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
